# Firebase 配置
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Drive 共享資料夾 ID
# 從 Google Drive 分享連結取得：https://drive.google.com/drive/folders/{FOLDER_ID}
VITE_GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# Cloudflare Worker 影片串流代理 URL
# 使用自訂網域（繞過 workers.dev subdomain 的底線 SSL 問題）
# DNS CNAME: family-drive-worker.yourdomain.com → family-drive-worker.{account}.workers.dev
VITE_CLOUDFLARE_WORKER_URL=https://family-drive-worker.yourdomain.com
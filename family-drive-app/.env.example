# Firebase configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudflare Worker video proxy URL
# Use a custom domain to avoid workers.dev subdomain TLS limitations on some networks.
# DNS CNAME example: family-drive-worker.yourdomain.com -> family-drive-worker.{account}.workers.dev
VITE_CLOUDFLARE_WORKER_URL=https://family-drive-worker.yourdomain.com

# Firebase Cloud Functions Drive API base URL
# Example: https://us-central1-your-project.cloudfunctions.net/driveApi
VITE_DRIVE_FUNCTIONS_BASE_URL=https://us-central1-your-project.cloudfunctions.net/driveApi
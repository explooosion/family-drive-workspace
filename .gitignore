# ──────────────────────────────────────────────
dist
dist-ssr
firebase/functions/lib

# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
node_modules

# ──────────────────────────────────────────────
# Cloudflare / Wrangler
# ──────────────────────────────────────────────
.wrangler/
worker-configuration.d.ts

# ──────────────────────────────────────────────
# NX cache

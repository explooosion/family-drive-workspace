# Firebase Functions runtime environment (example)
# Use Firebase config/secret manager in real deployment.

SHARED_DRIVE_FOLDER_ID=your_shared_google_drive_folder_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Comma-separated allowlist, for example:
# ALLOWED_ORIGINS=http://localhost:5173,https://robby570.tw
ALLOWED_ORIGINS=http://localhost:5173,https://robby570.tw

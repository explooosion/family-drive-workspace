# Optional CI/CD environment variables for worker deployment
# Do not store real secrets in this file.

CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_WORKER_NAME=family-drive-worker
CLOUDFLARE_WORKER_DOMAIN=family-drive-worker.yourdomain.com

# App origin allowed by worker CORS
ALLOWED_ORIGIN=https://yourdomain.com
